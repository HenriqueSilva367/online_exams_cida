<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Online Exams" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/navbar" if user_signed_in? && controller_name != 'home' %>
    
    <% if notice.present? || alert.present? %>
      <div class="flash-messages">
        <% if notice.present? %>
          <div class="flash flash-notice" data-controller="flash">
            <span><%= notice %></span>
            <button type="button" class="flash-close" data-action="click->flash#close">&times;</button>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="flash flash-alert" data-controller="flash">
            <span><%= alert %></span>
            <button type="button" class="flash-close" data-action="click->flash#close">&times;</button>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="<%= 'main-content' unless controller_name == 'home' %>">
      <%= yield %>
    </main>

    <!-- Modal Global de Confirmação (Turbo) -->
    <div id="turbo-confirm-modal" class="modal-overlay hidden" data-controller="turbo-confirm">
      <div id="modal-card" class="modal-card">
        <button id="modal-close" class="modal-close-btn">&times;</button>
        <div class="modal-header">
          <div class="modal-icon">⚠️</div>
          <h3 id="modal-message" class="modal-title">Tem certeza?</h3>
        </div>
        <div class="modal-footer">
          <button id="modal-cancel" class="btn-outline"><%= t('common.actions.cancel') %></button>
          <button id="modal-confirm" class="btn-primary"><%= t('common.actions.confirm') %></button>
        </div>
      </div>
    </div>
  </body>
</html>
