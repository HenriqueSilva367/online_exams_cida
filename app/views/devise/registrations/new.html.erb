<div class="auth-page-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <h2 class="auth-title">Create an Account</h2>
      <p class="auth-subtitle">Join Online Exams and start learning</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="auth-errors" style="color: #dc2626; background: #fee2e2; padding: 10px; border-radius: 6px; margin-bottom: 20px; font-size: 0.9em;">
          <%= render "devise/shared/error_messages", resource: resource %>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :name, "Full Name", class: "form-label" %>
        <div class="input-wrapper">
          <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-input", placeholder: "John Doe" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :email, "Email Address", class: "form-label" %>
        <div class="input-wrapper">
          <%= f.email_field :email, autocomplete: "email", class: "form-input", placeholder: "you@example.com" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :password, class: "form-label" do %>
          Password
          <% if @minimum_password_length %>
            <em style="font-size: 0.8em; color: var(--text-muted); font-weight: normal;">(<%= @minimum_password_length %> characters minimum)</em>
          <% end %>
        <% end %>
        <div class="input-wrapper">
          <%= f.password_field :password, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
        <div class="input-wrapper">
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", placeholder: "••••••••" %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit "Sign up", class: "btn-primary btn-block" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
