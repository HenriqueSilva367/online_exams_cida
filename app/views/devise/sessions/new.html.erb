<div class="auth-page-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <h2 class="auth-title">Welcome Back</h2>
      <p class="auth-subtitle">Sign in to your Online Exams account</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <div class="input-wrapper">
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "you@example.com" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :password, class: "form-label" %>
        <div class="input-wrapper">
          <%= f.password_field :password, autocomplete: "current-password", class: "form-input", placeholder: "••••••••" %>
        </div>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-group checkbox-group">
          <%= f.check_box :remember_me, class: "custom-checkbox" %>
          <%= f.label :remember_me, class: "checkbox-label" %>
        </div>
      <% end %>

      <div class="form-actions">
        <%= f.submit "Log in", class: "btn-primary btn-block" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
