<nav class="navbar">
  <div class="navbar-container">
    <div class="navbar-brand">
      <%= link_to authenticated_root_path, class: "brand-logo" do %>
        <span class="icon">🎓</span> Online Exams
      <% end %>
    </div>
    
    <div class="navbar-links">
      <% if current_user.admin? %>
        <%= link_to t('common.navbar.dashboard'), admin_root_path, class: "nav-link" %>
        <%= link_to t('common.navbar.topics'), admin_topics_path, class: "nav-link" %>
        <%= link_to t('common.navbar.students'), admin_users_path, class: "nav-link" %>
        <%= link_to t('common.navbar.reports'), admin_exam_sessions_path, class: "nav-link" %>
      <% else %>
        <%= link_to t('common.navbar.topics'), topics_path, class: "nav-link" %>
        <%= link_to t('common.navbar.my_exams'), exam_sessions_path, class: "nav-link" %>
      <% end %>
    </div>
    
    <div class="navbar-user">
      <span class="user-greeting"><%= t('common.navbar.hello', name: current_user.name&.split&.first || current_user.email.split('@').first) %> (<%= current_user.admin? ? t('common.navbar.admin') : t('common.navbar.student') %>)</span>
      
      <%= button_to t('common.navbar.logout'), destroy_user_session_path, method: :delete, class: "btn-logout" %>
    </div>
  </div>
</nav>
