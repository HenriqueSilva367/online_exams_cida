  <script>
    document.addEventListener("DOMContentLoaded", function() {
      // Carousel de Cursos (Infinito e Dinâmico)
      const inner = document.getElementById('carousel-inner');
      if (inner) {
        const slides = Array.from(inner.children);
        const totalOriginal = slides.length;
        
        // Clona todos os slides e adiciona ao final para criar o efeito de loop
        slides.forEach(slide => {
          const clone = slide.cloneNode(true);
          inner.appendChild(clone);
        });

        let currentSlide = 0;
        let isPaused = false;

        // Pausa no hover
        inner.parentElement.addEventListener('mouseenter', () => isPaused = true);
        inner.parentElement.addEventListener('mouseleave', () => isPaused = false);

        const moveCarousel = () => {
          if (isPaused) return;

          currentSlide++;
          inner.style.transition = 'transform 0.8s cubic-bezier(0.645, 0.045, 0.355, 1)';
          inner.style.transform = `translateX(-${currentSlide * 100}%)`;

          // Quando chegar no primeiro clone (que é igual ao primeiro original)
          if (currentSlide === totalOriginal) {
            // Espera a animação acabar e reseta instantaneamente
            setTimeout(() => {
              inner.style.transition = 'none';
              currentSlide = 0;
              inner.style.transform = `translateX(0)`;
            }, 800); // Mesmo tempo da transition CSS
          }
        };

        setInterval(moveCarousel, 5000);
      }

      // Hero Background Slider (Novo)
      const heroSlides = document.querySelectorAll('.hero-slide');
      let currentHeroSlide = 0;
      if (heroSlides.length > 0) {
        setInterval(() => {
          heroSlides[currentHeroSlide].classList.remove('active');
          currentHeroSlide = (currentHeroSlide + 1) % heroSlides.length;
          heroSlides[currentHeroSlide].classList.add('active');
        }, 6000); // 6 segundos por imagem
      }

      // Scroll Reveal para Seção de Simulador
      const simElements = document.querySelectorAll('.simulator-image, .simulator-content');
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
            entry.target.style.filter = 'blur(0)';
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      simElements.forEach((el, index) => {
        el.style.opacity = '0';
        el.style.filter = 'blur(10px)';
        el.style.transform = index === 0 ? 'translateX(-30px)' : 'translateX(30px)';
        el.style.transition = `all 1.2s cubic-bezier(0.22, 1, 0.36, 1) ${index * 0.2}s`;
        observer.observe(el);
      });
    });

  </script>

