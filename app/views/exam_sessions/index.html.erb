<div class="dashboard-header">
  <div>
    <h1 class="page-title">Meus Resultados</h1>
    <p class="page-subtitle">Histórico e pontuação de todas as suas provas passadas</p>
  </div>
</div>

<div class="topic-details-card" style="padding: 1rem; overflow-x: auto;">
  <table style="width: 100%; border-collapse: collapse; text-align: left;">
    <thead>
      <tr style="border-bottom: 2px solid var(--border-color);">
        <th style="padding: 1rem;">Prova / Tema</th>
        <th style="padding: 1rem;">Status</th>
        <th style="padding: 1rem;">Acertos / Score</th>
        <th style="padding: 1rem;">Tentativa Iniciada em</th>
        <th style="padding: 1rem; text-align: right;">Ação</th>
      </tr>
    </thead>
    <tbody>
      <% @exam_sessions.each do |session| %>
        <tr style="border-bottom: 1px solid var(--border-color);">
          <td style="padding: 1rem; font-weight: 600;">
            <%= session.exam&.topic&.title %> <span style="color: var(--text-muted); font-weight: normal;"> - <%= session.exam&.title %></span>
          </td>
          <td style="padding: 1rem;">
             <% if session.in_progress? %>
               <span style="background-color: #fef08a; color: #854d0e; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">Em Andamento</span>
             <% elsif session.completed? %>
               <span style="background-color: #dcfce7; color: #166534; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">Concluído</span>
             <% elsif session.canceled? %>
               <span style="background-color: #fef2f2; color: #991b1b; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">Cancelado</span>
             <% else %>
               <span style="background-color: #f1f5f9; color: #475569; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">Esgotado (Tempo)</span>
             <% end %>
          </td>
          <td style="padding: 1rem; font-weight: 600; font-size: 1.1rem; color: <%= session.score.to_i > 0 ? '#10b981' : 'var(--text-muted)' %>;">
            <%= session.score || 0 %>
          </td>
          <td style="padding: 1rem; color: var(--text-muted); font-size: 0.85rem;">
            <%= session.started_at&.strftime("%d/%m/%Y %H:%M") || "Sem registro" %>
          </td>
          <td style="padding: 1rem; text-align: right;">
            <% if session.in_progress? %>
              <%= link_to 'Continuar', exam_session_path(session), class: "btn-primary", style: "padding: 0.4rem 1rem; font-size: 0.85rem; text-decoration: none;" %>
            <% else %>
              <%= link_to 'Ver Boletim', results_exam_session_path(session), class: "btn-outline", style: "padding: 0.4rem 1rem; font-size: 0.85rem;" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  
  <% if @exam_sessions.empty? %>
    <div class="empty-state" style="margin-top: 1rem; background: transparent; border: none; min-height: 150px;">
      <p>Você ainda não iniciou nenhuma prova.</p>
    </div>
  <% end %>
</div>
