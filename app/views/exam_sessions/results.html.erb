<div class="dashboard-header" style="text-align: center; margin-bottom: 3rem;">
  <h1 class="page-title"><%= t('.title') %></h1>
  <p class="page-subtitle"><%= t('.subtitle', exam: @exam.title, topic: @exam.topic&.title || "Simulado ANAC Completo") %></p>
</div>

<div style="max-width: 900px; margin: 0 auto; padding-bottom: 4rem;">

  <% if @exam.anac_pp? %>
    <!-- Bloco de Resultado ANAC Detalhado -->
    <div style="background: var(--card-bg); border: 2px solid var(--border-color); border-radius: 1.5rem; padding: 2.5rem; margin-bottom: 4rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
      <h2 style="text-align: center; margin-bottom: 2rem; color: var(--text-main); font-size: 1.8rem; font-weight: 800;"><%= t('.detailed_anac.title') %></h2>
      
      <div style="text-align: center; margin-bottom: 2.5rem;">
        <% 
          status_color = case @exam_session.result_status
                        when 'approved' then '#10b981'
                        when 'second_chance' then '#f59e0b'
                        else '#ef4444'
                        end
          status_text = case @exam_session.result_status
                        when 'approved' then t('.status.approved')
                        when 'second_chance' then t('.status.second_chance')
                        when 'failed' then t('.status.failed')
                        else t('.status.pending')
                        end
        %>
        <span style="font-size: 1.3rem; font-weight: 900; padding: 1rem 2.5rem; border-radius: 999px; text-transform: uppercase; letter-spacing: 2px; background: <%= status_color %>; color: white;">
          <%= t('.status.final', status: status_text) %>
        </span>
      </div>

      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: separate; border-spacing: 0 0.8rem;">
          <thead>
            <tr style="color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; font-weight: 700;">
              <th style="text-align: left; padding: 0 1rem;"><%= t('.detailed_anac.table.subject') %></th>
              <th style="text-align: center; padding: 0 1rem;"><%= t('.detailed_anac.table.correct') %></th>
              <th style="text-align: center; padding: 0 1rem;"><%= t('.detailed_anac.table.total') %></th>
              <th style="text-align: center; padding: 0 1rem;"><%= t('.detailed_anac.table.min') %></th>
              <th style="text-align: center; padding: 0 1rem;"><%= t('.detailed_anac.table.evaluation') %></th>
            </tr>
          </thead>
          <tbody>
            <% (@exam_session.detailed_results || {}).each do |id, data| %>
              <tr style="background: rgba(0,0,0,0.02); border-radius: 1rem;">
                <td style="padding: 1.5rem 1rem; border-radius: 1rem 0 0 1rem; font-weight: 600; font-size: 1.1rem;"><%= data['title'] %></td>
                <td style="padding: 1.5rem 1rem; text-align: center; font-size: 1.3rem; font-weight: 800;"><%= data['correct'] %></td>
                <td style="padding: 1.5rem 1rem; text-align: center; color: var(--text-muted);"><%= data['total'] %></td>
                <td style="padding: 1.5rem 1rem; text-align: center; color: var(--text-muted);">14</td>
                <td style="padding: 1.5rem 1rem; border-radius: 0 1rem 1rem 0; text-align: center;">
                  <% if data['correct'].to_i >= 14 %>
                    <span style="background: #10b981; color: white; padding: 0.4rem 1rem; border-radius: 999px; font-size: 0.85rem; font-weight: bold;"><%= t('.detailed_anac.evaluation.ok') %></span>
                  <% elsif data['correct'].to_i < 6 %>
                    <span style="background: #ef4444; color: white; padding: 0.4rem 1rem; border-radius: 999px; font-size: 0.85rem; font-weight: bold;"><%= t('.detailed_anac.evaluation.critical') %></span>
                  <% else %>
                    <span style="background: #f59e0b; color: white; padding: 0.4rem 1rem; border-radius: 999px; font-size: 0.85rem; font-weight: bold;"><%= t('.detailed_anac.evaluation.below') %></span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <div style="margin-top: 2rem; padding: 1.5rem; background: #fefce8; border-radius: 1rem; border: 1px solid #fef08a;">
        <h4 style="margin: 0 0 0.5rem 0; color: #854d0e; font-size: 1rem; font-weight: 700;"><%= t('.anac_rules.title') %></h4>
        <ul style="margin: 0; padding-left: 1.5rem; color: #713f12; font-size: 0.9rem; line-height: 1.6;">
          <li><%= t('.anac_rules.rule1') %></li>
          <li><%= t('.anac_rules.rule2') %></li>
          <li><%= t('.anac_rules.rule3') %></li>
        </ul>
      </div>
    </div>
  <% end %>

  <!-- Painel de Desempenho / Resumo Numérico -->
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 4rem;">
    <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; text-align: center; border: 1px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-size: 3.5rem; font-weight: 800; color: var(--primary);"><%= @accuracy %>%</div>
      <div style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.5rem; font-weight: 600;"><%= t('.performance.accuracy') %></div>
    </div>
    <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; text-align: center; border: 1px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-size: 3.5rem; font-weight: 800; color: #10b981;"><%= @correct_answers %></div>
      <div style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.5rem; font-weight: 600;"><%= t('.performance.correct') %></div>
    </div>
    <div style="background: var(--card-bg); padding: 2rem; border-radius: 1rem; text-align: center; border: 1px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-size: 3.5rem; font-weight: 800; color: #ef4444;"><%= @incorrect_answers %></div>
      <div style="color: var(--text-muted); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.5rem; font-weight: 600;"><%= t('.performance.incorrect') %></div>
    </div>
  </div>

  <h3 style="margin-bottom: 2rem; text-align: center; color: var(--text-main); font-size: 1.8rem; border-bottom: 2px dashed var(--border-color); padding-bottom: 1rem;"><%= t('.feedback.title') %></h3>

  <!-- Gabarito Visual Card by Card -->
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    <% @questions.each_with_index do |q, index| %>
      <% 
        student_answer = @exam_session.session_answers.find { |sa| sa.question_id == q.id }&.answer
        is_hit = student_answer&.is_correct
        card_border = is_hit ? '#34d399' : '#fca5a5'
        card_bg = is_hit ? '#f0fdf4' : '#fef2f2'
      %>
      
      <div style="border: 2px solid <%= card_border %>; background: <%= card_bg %>; border-radius: 1rem; padding: 2rem; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);">
        <h4 style="margin: 0 0 1.5rem 0; font-size: 1.15rem; color: #1f2937; line-height: 1.5;">
          <strong><%= index + 1 %>.</strong> <%= q.title %>
          <% if student_answer.nil? %>
             <span style="background: #fef08a; color: #854d0e; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: bold; margin-left: 1rem;"><%= t('.feedback.left_blank') %></span>
          <% end %>
        </h4>
        
        <ul style="list-style: none; padding-left: 0; margin: 0; display: flex; flex-direction: column; gap: 0.8rem;">
          <% q.answers.each do |ans| %>
            <% 
               is_student_selection = (student_answer&.id == ans.id)
               is_actual_correct = ans.is_correct
            %>
            <li style="padding: 1rem; border-radius: 0.5rem; display: flex; align-items: center; gap: 1rem;
              background: <%= is_actual_correct ? '#10b981' : (is_student_selection ? '#ef4444' : '#ffffff') %>;
              color: <%= (is_actual_correct || is_student_selection) ? '#ffffff' : '#374151' %>;
              border: 1px solid <%= (is_actual_correct || is_student_selection) ? 'transparent' : 'var(--border-color)' %>; 
              font-size: 1.05rem;
            ">
              <% if is_actual_correct %>
                <span style="font-weight: bold; font-size: 1.4rem;">✓</span>
              <% elsif is_student_selection %>
                <span style="font-weight: bold; font-size: 1.4rem;">✖</span>
              <% else %>
                <span style="display: inline-block; width: 1.4rem;"></span>
              <% end %>
              <span style="<%= (is_actual_correct || is_student_selection) ? 'font-weight: 600;' : '' %>"><%= ans.title %></span>
              
              <!-- Badges laterais informativas -->
              <% if is_student_selection && is_actual_correct %>
                <span style="margin-left: auto; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; background: rgba(0,0,0,0.25); color: white; padding: 0.4rem 0.8rem; border-radius: 999px;"><%= t('.feedback.your_correct') %></span>
              <% elsif is_student_selection && !is_actual_correct %>
                <span style="margin-left: auto; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; background: rgba(0,0,0,0.25); color: white; padding: 0.4rem 0.8rem; border-radius: 999px;"><%= t('.feedback.where_failed') %></span>
              <% elsif is_actual_correct && !is_student_selection %>
                <span style="margin-left: auto; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; background: rgba(0,0,0,0.15); color: white; padding: 0.4rem 0.8rem; border-radius: 999px;"><%= t('.feedback.actual_correct') %></span>
              <% end %>
            </li>
          <% end %>
        </ul>

        <% if q.explanation.present? %>
          <div class="explanation-container" style="margin-top: 1.5rem; padding: 1.5rem; background: #fff; border: 1px solid <%= card_border %>; border-radius: 0.8rem; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
            <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <span style="font-size: 1.2rem;">🔍</span>
              <div>
                <strong style="display: block; margin-bottom: 0.5rem; color: #92400e; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.5px;">Referência Técnica / Base Legal:</strong>
                <div style="font-size: 0.95rem; color: #4b5563; line-height: 1.6;">
                  <%= render_explanation_with_images(q) %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
<% end %>
  </div>

  <div style="text-align: center; margin-top: 4rem;">
    <%= link_to t('.actions.back'), exam_sessions_path, class: "btn-primary", style: "padding: 0.8rem 2.5rem; font-size: 1.1rem; border-radius: 999px; text-decoration: none;" %>
  </div>
</div>
