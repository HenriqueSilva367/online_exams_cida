<style>
  :root {
    --id-primary: #0a0e27;
    --id-accent: #ffa722;
    --id-cobalt: #0047AB;
    --id-bg: #f1f5f9;
    --id-card-bg: #ffffff;
    --id-text: #1e293b;
    --id-text-muted: #64748b;
  }

  .id-card-body {
    background-color: var(--id-bg);
    min-height: 100vh;
    padding: 3rem 1rem;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .id-card-container {
    max-width: 500px;
    margin: 0 auto;
  }

  /* Digital ID Card Style */
  .id-card {
    background: var(--id-card-bg);
    border-radius: 28px;
    box-shadow: 0 20px 40px -10px rgba(10, 14, 39, 0.15);
    overflow: hidden;
    position: relative;
    border: 1px solid #e2e8f0;
  }

  .id-card-header {
    background: var(--id-primary);
    height: 120px;
    position: relative;
    display: flex;
    justify-content: center;
  }

  .id-card-header::after {
    content: "";
    position: absolute;
    bottom: -50px;
    width: 100%;
    height: 100px;
    background: var(--id-card-bg);
    border-radius: 50% 50% 0 0;
  }

  .id-avatar-wrapper {
    position: absolute;
    top: 50px;
    z-index: 10;
  }

  .id-avatar {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    border: 5px solid white;
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    background: white;
    object-fit: cover;
  }

  .id-content {
    padding: 80px 2.5rem 2.5rem 2.5rem;
    text-align: center;
  }

  .id-name {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--id-primary);
    margin-bottom: 0.25rem;
  }

  .id-type {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: rgba(255, 167, 34, 0.15);
    color: #92400e;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  .id-info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    text-align: left;
    margin-bottom: 2.5rem;
  }

  .id-info-item {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid #f1f5f9;
    padding-bottom: 0.75rem;
  }

  .id-info-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--id-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.025em;
    margin-bottom: 0.25rem;
  }

  .id-info-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--id-text);
  }

  .id-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-id-primary {
    background: var(--id-cobalt);
    color: white;
    padding: 1rem;
    border-radius: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s;
    box-shadow: 0 4px 12px rgba(0, 71, 171, 0.2);
  }

  .btn-id-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 71, 171, 0.3);
    filter: brightness(1.1);
  }

  .btn-id-back {
    color: var(--id-text-muted);
    font-size: 0.875rem;
    text-decoration: none;
    font-weight: 500;
  }

  .btn-id-back:hover {
    color: var(--id-primary);
  }

  /* Decorative elements */
  .id-chip {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 40px;
    height: 30px;
    background: linear-gradient(135deg, #ffd700, #b8860b);
    border-radius: 6px;
    opacity: 0.3;
  }
</style>

<div class="id-card-body">
  <div class="id-card-container">
    <div class="id-card">
      <div class="id-chip"></div>
      <div class="id-card-header">
        <div class="id-avatar-wrapper">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, class: "id-avatar" %>
          <% else %>
            <div class="id-avatar" style="display: flex; align-items:center; justify-content:center; color: #cbd5e1; background: #f8fafc;">
              <svg width="60" height="60" fill="currentColor" viewBox="0 0 24 24"><path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            </div>
          <% end %>
        </div>
      </div>

      <div class="id-content">
        <h2 class="id-name"><%= @user.full_name.presence || "Nome não informado" %></h2>
        <div class="id-type"><%= @user.student_type&.humanize || "Visitante" %></div>

        <div class="id-info-grid">
          <div class="id-info-item">
            <span class="id-info-label">E-mail Acadêmico</span>
            <span class="id-info-value"><%= @user.email %></span>
          </div>
          <div class="id-info-item">
            <span class="id-info-label">Telefone / Contato</span>
            <span class="id-info-value"><%= @user.phone.presence || "Não informado" %></span>
          </div>
          <div class="id-info-item">
            <span class="id-info-label">Código CANAC</span>
            <span class="id-info-value"><%= @user.canac.presence || "--- ---" %></span>
          </div>
          <div class="id-info-item">
            <span class="id-info-label">CPF</span>
            <span class="id-info-value"><%= @user.cpf.presence || "--- --- --- --" %></span>
          </div>
        </div>

        <div class="id-actions">
          <%= link_to "Editar Informações", edit_profile_path, class: "btn-id-primary" %>
          <%= link_to "Voltar ao Início", root_path, class: "btn-id-back" %>
        </div>
      </div>
    </div>
  </div>
</div>
