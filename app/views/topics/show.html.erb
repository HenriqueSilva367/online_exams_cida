<div class="dashboard-header">
  <div>
    <h1 class="page-title"><%= @topic.title %></h1>
    <p class="page-subtitle"><%= @topic.description %></p>
  </div>
  <div class="header-actions">
    <%= link_to '← Voltar para Provas Abertas', topics_path, class: "btn-outline", style: "text-decoration: none;" %>
  </div>
</div>

<div class="topic-details-card" style="padding: 1rem; overflow-x: auto;">
  <h3 style="margin: 0 0 1rem 1rem; color: var(--text-main);">Exames Disponíveis</h3>
  
  <table style="width: 100%; border-collapse: collapse; text-align: left;">
    <thead>
      <tr style="border-bottom: 2px solid var(--border-color);">
        <th style="padding: 1rem;">Prova / Exame</th>
        <th style="padding: 1rem;">Dificuldade</th>
        <th style="padding: 1rem;">Duração</th>
        <th style="padding: 1rem; text-align: right;">Ação</th>
      </tr>
    </thead>
    <tbody>
      <% @exams.each do |exam| %>
        <tr style="border-bottom: 1px solid var(--border-color);">
          <td style="padding: 1rem; font-weight: 600;"><%= exam.title || "Exame sem nome" %></td>
          <td style="padding: 1rem;">
            <span style="background-color: #f3f4f6; color: #4b5563; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">
              <%= exam.difficulty || "Padrão" %>
            </span>
          </td>
          <td style="padding: 1rem; color: var(--text-muted); font-size: 0.85rem;">
            <%= exam.time_duration || 0 %> minutos
          </td>
          <td style="padding: 1rem; text-align: right;">
            <button type="button" onclick="document.getElementById('modal-exam-<%= exam.id %>').showModal()" class="btn-primary" style="padding: 0.4rem 1rem; font-size: 0.85rem; border: none; cursor: pointer;">
              Iniciar Prova
            </button>

            <!-- O Modal Nativo -->
            <dialog id="modal-exam-<%= exam.id %>" class="exam-modal">
              <div class="modal-content" style="text-align: left;">
                <h3 style="margin-top: 0; color: var(--text-main);">Atenção, Estudante!</h3>
                <p style="color: var(--text-muted); line-height: 1.5;">Você está prestes a iniciar seu cronômetro para o exame <strong><%= exam.title %></strong>.</p>
                <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.5; background: #fef2f2; border: 1px solid #fca5a5; padding: 0.8rem; border-radius: 0.5rem; color: #991b1b;">
                  O tempo de <strong><%= exam.time_duration %> minutos</strong> começará a rodar assim que você aceitar, e <strong>não pode ser pausado</strong> mesmo se você fechar a aba!
                </p>
                
                <div style="margin-top: 1.5rem; padding: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.75rem;">
                  <label style="display: block; font-weight: 700; color: #1e293b; margin-bottom: 0.5rem; font-size: 0.95rem;">Modo de Estudo:</label>
                  <%= form_with url: exam_exam_sessions_path(exam), method: :post, local: true do |f| %>
                    <div style="margin-bottom: 1rem;">
                      <%= f.select :selected_topic_id, 
                          # Aqui buscamos os tópicos/matérias que existem nas questões dessa prova
                          options_from_collection_for_select(Topic.where(id: exam.questions.select(:topic_id).distinct.compact), :id, :title),
                          { include_blank: "Simulado Completo (Todas as Matérias)" },
                          { class: "subject-select-field", style: "width: 100%; padding: 0.6rem; border-radius: 0.5rem; border: 1px solid #cbd5e1; font-size: 0.9rem;" } 
                      %>
                    </div>

                    <p id="info-timer-<%= exam.id %>" style="font-size: 0.8rem; color: #475569; margin: 0 0 1.5rem 0;">
                      <i class="fas fa-clock"></i> Selecione acima para ajustar o tempo.
                    </p>

                    <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                      <button type="button" onclick="document.getElementById('modal-exam-<%= exam.id %>').close()" class="btn-outline" style="border: none; cursor: pointer;">Cancelar</button>
                      <%= f.submit 'Sim, Iniciar!', class: "btn-primary", style: "border: none; cursor: pointer;" %>
                    </div>
                  <% end %>
                </div>
              </div>
            </dialog>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @exams.empty? %>
    <div class="empty-state" style="margin-top: 1rem; background: transparent; border: none; min-height: 150px;">
      <p>Nenhuma prova foi cadastrada nesta disciplina pelo Administrador ainda.</p>
    </div>
  <% end %>
</div>
