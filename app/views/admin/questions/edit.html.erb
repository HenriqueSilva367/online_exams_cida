<div class="auth-page-wrapper">
  <div class="auth-card" style="max-width: 650px;">
    <div class="auth-header">
      <h2 class="auth-title">Editar Pergunta</h2>
      <p class="auth-subtitle">Modifique o Enunciado da sua Questão</p>
    </div>

    <% parent = @question.topic || @question.exam %>
    <%= render "form", question: @question, parent: parent %>

    <div class="auth-footer" style="margin-top: 1.5rem;">
      <%= link_to '← Cancelar e Voltar', (parent.is_a?(Topic) ? admin_topic_path(parent) : admin_exam_path(parent)) %>
    </div>
  </div>
</div>
