<%= form_with(model: [:admin, topic], class: "auth-form") do |form| %>
  <% if topic.errors.any? %>
    <div class="flash flash-alert">
      <strong>Ops! Temos <%= pluralize(topic.errors.count, "erro") %>:</strong>
      <ul style="margin: 0.5rem 0 0 1rem; font-size: 0.85rem;">
        <% topic.errors.full_messages.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, "Título do Tópico", class: "form-label" %>
    <div class="input-wrapper">
      <%= form.text_field :title, class: "form-input", placeholder: "Ex: Matemática Financeira" %>
    </div>
  </div>

  <div class="form-group">
    <%= form.label :description, "Descrição", class: "form-label" %>
    <div class="input-wrapper">
      <%= form.text_area :description, class: "form-input", rows: 4, placeholder: "Breve resumo sobre este tópico..." %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit "Salvar Tópico", class: "btn-primary btn-block" %>
  </div>
<% end %>
