<div class="dashboard-header">
  <div>
    <h1 class="page-title"><%= @exam.title %></h1>
    <p class="page-subtitle">Dificuldade: <strong><%= @exam.difficulty %></strong> | Tempo: <strong><%= @exam.time_duration %> min</strong></p>
  </div>
  <div class="header-actions">
    <%= link_to '✏️ Alterar Regras', edit_admin_exam_path(@exam), class: "btn-outline", style: "text-decoration: none;" %>
    <%= link_to '← Voltar à Trilha', admin_topic_path(@exam.topic), class: "btn-outline" %>
  </div>
</div>

<div class="topic-details-card" style="margin-top: 2rem;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h3 style="margin: 0; color: var(--text-main);">Banco de Questões</h3>
    <%= link_to '➕ Adicionar Nova Questão', new_admin_exam_question_path(@exam), class: "btn-primary", style: "text-decoration: none;" %>
  </div>

  <% if @questions.any? %>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <% @questions.each_with_index do |q, index| %>
        <div style="border: 1px solid var(--border-color); border-radius: 0.5rem; padding: 1.5rem; background: #fafafa;">
          <h4 style="margin: 0 0 1rem 0; font-size: 1.1rem;">
            <strong>Questão <%= index + 1 %>:</strong> <%= q.title %>
          </h4>
          
          <ul style="list-style: none; padding-left: 0; margin-bottom: 1.5rem;">
            <% q.answers.each do |ans| %>
              <li style="padding: 0.5rem; border-bottom: 1px dashed #e5e7eb; display: flex; align-items: center; gap: 0.5rem;">
                <% if ans.is_correct %>
                  <span style="color: #10b981; font-weight: bold;">✔</span>
                <% else %>
                  <span style="color: #ef4444; font-weight: bold;">✖</span>
                <% end %>
                <%= ans.title %>
              </li>
            <% end %>
          </ul>

          <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
            <%= link_to 'Gerenciar e Editar Questão', admin_question_path(q), class: "btn-outline", style: "font-size: 0.8rem; padding: 0.3rem 0.6rem;" %>
            <%= button_to 'Remover', admin_question_path(q), method: :delete, form: { data: { turbo_confirm: 'Deseja excluir esta questão do teste?' } }, class: "btn-danger", style: "font-size: 0.8rem; padding: 0.3rem 0.6rem;" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state" style="background: transparent; border: 1px dashed var(--border-color); padding: 2rem;">
      <p>A prova ainda não possui nenhuma pergunta.</p>
    </div>
  <% end %>
</div>
