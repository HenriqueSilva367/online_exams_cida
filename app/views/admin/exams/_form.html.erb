<% 
  url_target = exam.persisted? ? [:admin, exam] : [:admin, topic, exam] 
%>

<%= form_with(model: url_target, class: "auth-form") do |form| %>
  <% if exam.errors.any? %>
    <div class="flash flash-alert">
      <strong>Ops! <%= pluralize(exam.errors.count, "erro") %> encontrado:</strong>
      <ul style="margin: 0.5rem 0 0 1rem; font-size: 0.85rem;">
        <% exam.errors.full_messages.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, "Nome da Prova", class: "form-label" %>
    <div class="input-wrapper">
      <%= form.text_field :title, class: "form-input", placeholder: "Ex: Simulado de Biologia 01" %>
    </div>
  </div>

  <div class="form-group">
    <%= form.label :description, "Instruções ou Descrição", class: "form-label" %>
    <div class="input-wrapper">
      <%= form.text_area :description, class: "form-input", rows: 3, placeholder: "Regras do teste ou mensagem de boa sorte..." %>
    </div>
  </div>

  <div class="form-group" style="display: flex; gap: 1rem;">
    <div style="flex: 1;">
      <%= form.label :difficulty, "Nível de Dificuldade", class: "form-label" %>
      <div class="input-wrapper" style="position: relative;">
        <%= form.select :difficulty, ['Fácil', 'Médio', 'Difícil'], { prompt: 'Selecione...' }, { class: "form-input", style: "appearance: none; cursor: pointer;" } %>
        <div style="position: absolute; right: 1rem; top: 1rem; pointer-events: none; color: var(--text-muted);">▼</div>
      </div>
    </div>

    <div style="flex: 1;">
      <%= form.label :time_duration, "Cronômetro (em Minutos)", class: "form-label" %>
      <div class="input-wrapper">
        <%= form.number_field :time_duration, class: "form-input", min: 1, placeholder: "Ex: 60" %>
      </div>
    </div>
  </div>

  <div class="form-actions" style="margin-top: 2.5rem;">
    <%= form.submit "Salvar e Continuar", class: "btn-primary btn-block" %>
  </div>
<% end %>
