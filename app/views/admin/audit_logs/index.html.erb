<div class="dashboard-header">
  <div>
    <h1 class="page-title">Log de Auditoria</h1>
    <p class="page-subtitle">Histórico completo de todas as alterações realizadas no sistema por administradores e alunos.</p>
  </div>
</div>

<div class="topic-details-card" style="padding: 1rem; overflow-x: auto;">
  <table style="width: 100%; border-collapse: collapse; text-align: left;">
    <thead>
      <tr style="border-bottom: 2px solid var(--border-color);">
        <th style="padding: 1rem;">Data/Hora</th>
        <th style="padding: 1rem;">Usuário</th>
        <th style="padding: 1rem;">Ação</th>
        <th style="padding: 1rem;">Entidade</th>
        <th style="padding: 1rem;">Alterações</th>
      </tr>
    </thead>
    <tbody>
      <% @versions.each do |version| %>
        <tr style="border-bottom: 1px solid var(--border-color);">
          <td style="padding: 1rem; white-space: nowrap; font-size: 0.85rem;">
            <%= version.created_at.strftime("%d/%m/%Y %H:%M:%S") %>
          </td>
          
          <td style="padding: 1rem; font-size: 0.85rem;">
            <% if version.whodunnit %>
              <% user = User.find_by(id: version.whodunnit) %>
              <strong><%= user&.full_name || "ID: #{version.whodunnit}" %></strong>
              <div style="font-size: 0.75rem; color: var(--text-muted);"><%= user&.email %></div>
            <% else %>
              <span style="color: var(--text-muted);">Sistema / Guest</span>
            <% end %>
          </td>
          
          <td style="padding: 1rem;">
            <% action_style = case version.event
               when 'create' then "background-color: #dcfce7; color: #166534;"
               when 'update' then "background-color: #dbeafe; color: #1e40af;"
               when 'destroy' then "background-color: #fecaca; color: #991b1b;"
               end %>
            <span style="<%= action_style %> padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase;">
              <%= { 'create' => 'CRIOU', 'update' => 'EDITOU', 'destroy' => 'APAGOU' }[version.event] %>
            </span>
          </td>
          
          <td style="padding: 1rem; font-size: 0.85rem;">
            <div style="font-weight: 600;"><%= version.item_type %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted);">ID: <%= version.item_id %></div>
          </td>
          
          <td style="padding: 1rem; font-size: 0.8rem; vertical-align: top; max-width: 300px;">
            <% if version.event == 'update' && version.changeset.present? %>
              <details style="width: 100%;">
                <summary style="cursor: pointer; color: var(--primary); font-weight: 600; outline: none;">Ver detalhes</summary>
                <div style="margin-top: 0.75rem; padding: 0.75rem; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border-color); overflow-wrap: break-word; word-break: break-word;">
                  <% version.changeset.each do |field, values| %>
                    <% next if ['updated_at', 'created_at', 'encrypted_password'].include?(field) %>
                    <div style="margin-bottom: 0.75rem; last-child { margin-bottom: 0; }">
                      <div style="font-weight: 700; color: var(--text-main); font-size: 0.7rem; text-transform: uppercase; margin-bottom: 0.25rem;"><%= field.humanize %></div>
                      <div style="display: flex; flex-direction: column; gap: 0.25rem; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 0.75rem;">
                        <div style="color: #991b1b; background: #fee2e2; padding: 0.2rem 0.5rem; border-radius: 4px; position: relative; padding-left: 1.5rem;">
                          <span style="position: absolute; left: 0.5rem; font-weight: bold; opacity: 0.5;">-</span>
                          <%= values[0].inspect %>
                        </div>
                        <div style="color: #166534; background: #dcfce7; padding: 0.2rem 0.5rem; border-radius: 4px; position: relative; padding-left: 1.5rem;">
                          <span style="position: absolute; left: 0.5rem; font-weight: bold; opacity: 0.5;">+</span>
                          <%= values[1].inspect %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </details>
            <% elsif version.event == 'create' %>
              <span style="color: var(--text-muted); font-style: italic;">Registro inicial criado</span>
            <% elsif version.event == 'destroy' %>
              <span style="color: #991b1b; font-weight: 600; background: #fee2e2; padding: 0.2rem 0.5rem; border-radius: 4px;">Registro removido</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  
  <% if @versions.empty? %>
    <div style="padding: 3rem; text-align: center; color: var(--text-muted);">
      <p>Nenhuma atividade registrada no log de auditoria ainda.</p>
    </div>
  <% end %>
</div>
