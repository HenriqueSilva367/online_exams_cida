<div class="dashboard-header">
  <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
    <div>
      <h1 class="page-title">Gestão de Alunos (Usuários)</h1>
      <p class="page-subtitle">Visualize ou altere os níveis de acesso e créditos dos alunos.</p>
    </div>
    <%= link_to "Novo Usuário (Aluno)", new_admin_user_path, class: "btn-primary", style: "background-color: var(--primary); padding: 0.8rem 1.5rem; width: 20%; text-align: center;" %>
  </div>
</div>

<div class="topic-details-card" style="padding: 1.5rem; margin-bottom: 2rem;">
  <%= form_with url: admin_users_path, method: :get, local: true, class: "search-form" do |f| %>
    <%= f.label :q, "Buscar Aluno (Nome ou CPF)", class: "form-label", style: "display: block; margin-bottom: 0.5rem;" %>
    <div style="display: flex; gap: 0.5rem; align-items: stretch;">
      <%= f.text_field :q, value: params[:q], placeholder: "Digite o nome ou CPF...", class: "form-input", style: "flex: 1; max-width: 80%;" %>
      <%= f.submit "Pesquisar", class: "btn-primary", style: "padding: 0 1.5rem; width: auto; font-size: 0.9rem;" %>
      <% if params[:q].present? %>
        <%= link_to "Limpar", admin_users_path, class: "btn-outline", style: "padding: 0.75rem 1.5rem; text-decoration: none; display: flex; align-items: center;" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="topic-details-card" style="padding: 0; overflow-x: auto; border: 1px solid var(--border-color); border-radius: 1.5rem;">
  <table style="width: 100%; border-collapse: collapse; text-align: left;">
    <thead>
      <tr style="background: #f8fafc; border-bottom: 2px solid var(--border-color);">
        <th style="padding: 1.25rem 1rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">Aluno / E-mail</th>
        <th style="padding: 1.25rem 1rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">Documentos</th>
        <th style="padding: 1.25rem 1rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); text-align: center;">Creds</th>
        <th style="padding: 1.25rem 1rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); text-align: center;">Pts</th>
        <th style="padding: 1.25rem 1rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); text-align: center;">Ações Acadêmicas</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.2s;" onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='transparent'">
          <td style="padding: 1rem;">
            <div style="font-weight: 700; color: var(--text-main); font-size: 0.95rem; white-space: nowrap;"><%= user.full_name.presence || 'Sem nome' %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted);"><%= user.email %></div>
          </td>
          <td style="padding: 1rem; font-size: 0.8rem; white-space: nowrap;">
            <div><%= user.cpf.presence || '-' %></div>
            <div style="color: var(--text-muted); font-size: 0.7rem;">C: <%= user.canac.presence || '-' %></div>
          </td>
          <td style="padding: 1rem; text-align: center; font-weight: 900; color: var(--primary); font-size: 1.1rem;">
            <%= user.credits %>
          </td>
          <td style="padding: 1rem; text-align: center; font-weight: 800; color: #10b981;">
            <%= user.total_points %>
          </td>
          <td style="padding: 1rem; width: 400px; min-width: 400px;">
            <div style="display: flex; gap: 8px; justify-content: flex-start; align-items: center; white-space: nowrap;">
              <% if user.student? %>
                <div style="display: flex; align-items: center; height: 32px; flex-shrink: 0;">
                  <%= form_with url: add_credits_admin_user_path(user), method: :post, local: true, style: "display: flex; margin: 0; align-items: center; gap: 8px;" do |f| %>
                    <%= hidden_field_tag :q, params[:q] %>
                    <%= f.number_field :amount, value: 5, min: 1, style: "width: 45px; padding: 0 4px; font-size: 0.8rem; text-align: center; height: 32px; border: 1px solid #cbd5e1; background: white; border-radius: 6px; box-sizing: border-box;" %>
                    <%= f.submit "+Crédito", class: "btn-outline", style: "background: transparent; border: 1px solid #10b981; color: #10b981; padding: 0 10px; font-size: 0.75rem; height: 32px; cursor: pointer; font-weight: 700; border-radius: 6px; box-sizing: border-box;" %>
                  <% end %>
                </div>
              <% end %>
              
              <%= link_to '⚙️ Gestão', admin_user_path(user), class: "btn-outline", style: "padding: 0 10px; font-size: 0.75rem; height: 32px; display: flex; align-items: center; font-weight: 700; text-decoration: none; border: 1px solid var(--primary); color: var(--primary); border-radius: 6px;" %>
              <%= link_to '✏️', edit_admin_user_path(user), class: "btn-outline", style: "padding: 0 10px; font-size: 0.75rem; height: 32px; display: flex; align-items: center; border-radius: 6px; text-decoration: none; border: 1px solid #cbd5e1;" %>
              
              <% unless user == current_user %>
                <%= button_to '🗑️', admin_user_path(user), method: :delete, form: { data: { turbo_confirm: 'Excluir aluno?' }, style: "margin:0;" }, class: "btn-danger", style: "padding: 0 10px; font-size: 0.75rem; height: 32px; min-width: auto; border-radius: 6px;" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  
  <% if @users.empty? %>
    <div style="padding: 3rem; text-align: center; color: var(--text-muted); background: white;">
      <p>Nenhum usuário encontrado no sistema.</p>
    </div>
  <% end %>
</div>
