<div class="dashboard-header">
  <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
    <div>
      <h1 class="page-title">Gestão de Alunos (Usuários)</h1>
      <p class="page-subtitle">Visualize ou altere os níveis de acesso e créditos dos alunos.</p>
    </div>
    <%= link_to "Novo Usuário (Aluno)", new_admin_user_path, class: "btn-primary", style: "background-color: var(--primary); padding: 0.8rem 1.5rem; width: 20%; text-align: center;" %>
  </div>
</div>

<div class="topic-details-card" style="padding: 1.5rem; margin-bottom: 2rem;">
  <%= form_with url: admin_users_path, method: :get, local: true, class: "search-form" do |f| %>
    <%= f.label :q, "Buscar Aluno (Nome ou CPF)", class: "form-label", style: "display: block; margin-bottom: 0.5rem;" %>
    <div style="display: flex; gap: 0.5rem; align-items: stretch;">
      <%= f.text_field :q, value: params[:q], placeholder: "Digite o nome ou CPF...", class: "form-input", style: "flex: 1; max-width: 80%;" %>
      <%= f.submit "Pesquisar", class: "btn-primary", style: "padding: 0 1.5rem; width: auto; font-size: 0.9rem;" %>
      <% if params[:q].present? %>
        <%= link_to "Limpar", admin_users_path, class: "btn-outline", style: "padding: 0.75rem 1.5rem; text-decoration: none; display: flex; align-items: center;" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="topic-details-card" style="padding: 1rem; overflow-x: auto;">
  <table style="width: 100%; border-collapse: collapse; text-align: left;">
    <thead>
      <tr style="border-bottom: 2px solid var(--border-color);">
        <th style="padding: 1rem;">Nome / E-mail</th>
        <th style="padding: 1rem;">CPF / CANAC</th>
        <th style="padding: 1rem;">Categoria</th>
        <th style="padding: 1rem;">Cargo</th>
        <th style="padding: 1rem; text-align: center;">Créditos</th>
        <th style="padding: 1rem; text-align: center;">Pontos</th>
        <th style="padding: 1rem; text-align: center;">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr style="border-bottom: 1px solid var(--border-color); hover: background-color: #f8fafc;">
          <td style="padding: 1rem;">
            <div style="font-weight: 600; color: var(--text-main);"><%= user.full_name.presence || 'Sem nome' %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted);"><%= user.email %></div>
          </td>
          <td style="padding: 1rem; font-size: 0.85rem;">
            <div><%= user.cpf.presence || '-' %></div>
            <div style="color: var(--text-muted);">C: <%= user.canac.presence || '-' %></div>
          </td>
          <td style="padding: 1rem; font-size: 0.85rem; font-weight: 500;">
            <%= user.student_type&.humanize || '-' %>
          </td>
          <td style="padding: 1rem;">
            <% role_style = case user.role
               when 'admin' then "background-color: #fef08a; color: #854d0e;"
               when 'professor' then "background-color: #dcfce7; color: #166534;"
               when 'supervisor' then "background-color: #fef3c7; color: #92400e;"
               else "background-color: #bfdbfe; color: #1e40af;"
               end %>
            <span style="<%= role_style %> padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase;">
              <%= user.role.humanize %>
            </span>
          </td>
          <td style="padding: 1rem; text-align: center; font-weight: 800; color: var(--primary);">
            <%= user.credits %>
          </td>
          <td style="padding: 1rem; text-align: center; font-weight: 800; color: #10b981;">
            <%= user.total_points %>
          </td>
          <td style="padding: 1rem; text-align: center;">
            <div style="display: flex; gap: 1rem; justify-content: center; align-items: center; flex-wrap: nowrap;">
              <% if user.student? %>
                <%= form_with url: add_credits_admin_user_path(user), method: :patch, local: true, style: "display: flex; flex-direction: row; gap: 4px; align-items: center; margin: 0; min-width: max-content;" do |f| %>
                  <%= hidden_field_tag :q, params[:q] %>
                  <%= f.number_field :amount, value: 5, min: 1, style: "width: 50px; padding: 0 4px; font-size: 0.85rem; text-align: center; height: 32px; border: 1px solid #cbd5e1; border-radius: 6px; background: white; box-sizing: border-box;" %>
                  <%= f.submit "+ Crédito", class: "btn-credit-outline", style: "background: transparent; border: 1px solid #10b981; color: #10b981; padding: 0 10px; font-size: 0.8rem; height: 32px; border-radius: 6px; cursor: pointer; white-space: nowrap; font-weight: 500; transition: all 0.2s;" %>
                <% end %>
              <% end %>
              
              <div style="display: flex; gap: 0.5rem; align-items: center;">
                <%= link_to 'Editar', edit_admin_user_path(user), class: "btn-outline", style: "padding: 0 0.8rem; font-size: 0.8rem; height: 32px; display: flex; align-items: center; text-decoration: none; white-space: nowrap;" %>
                <% unless user == current_user %>
                  <%= button_to 'Excluir', admin_user_path(user), method: :delete, form: { data: { turbo_confirm: 'Certeza?' } }, class: "btn-danger", style: "padding: 0 0.8rem; font-size: 0.8rem; height: 32px; display: flex; align-items: center; justify-content: center; white-space: nowrap;" %>
                <% end %>
              </div>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  
  <% if @users.empty? %>
    <div style="padding: 3rem; text-align: center; color: var(--text-muted);">
      <p>Nenhum usuário encontrado no sistema.</p>
    </div>
  <% end %>
</div>
